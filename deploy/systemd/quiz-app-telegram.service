[Unit]
Description=Quiz-App Telegram Bot
After=network.target

[Service]
Type=simple
User=beneves
Group=beneves
WorkingDirectory=/home/beneves/quiz-app
EnvironmentFile=/home/beneves/quiz-app/.env
ExecStart=/home/beneves/quiz-app/.venv/bin/python bot_telegram.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
